PORT=3001
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
# Clave de servicio (service_role) — bypassa RLS, solo para backend. Obtener en Supabase > Settings > API
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
N8N_WEBHOOK_URL=https://n8n.suizalabgroup.com/webhook/vidalis-video-upload
N8N_VIRAL_SCORE_URL=https://n8n.suizalabgroup.com/webhook/viral-score
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
CLOUDINARY_UPLOAD_PRESET=tu-upload-preset

# Seguridad
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Secreto compartido con n8n para proteger el webhook de callback
WEBHOOK_SECRET=secreto-compartido-con-n8n

# Entorno (development o production)
NODE_ENV=development
